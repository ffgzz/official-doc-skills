#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
session_context=$(cat <<'MSG'
<EXTREMELY_IMPORTANT>
你已加载“公文项目写作助手”。

当用户提出以下任一任务时，你必须先按 `skills/using-official-docs/SKILL.md` 处理，而不是直接自由发挥：
- 我要写 ZS-项目可行性报告，材料在 ...
- 我要写 完整科研项目模板，材料在 ...
- 继续修改、补写、补表、补图、复核、合稿上述两类文档

把“文档类型 + 材料路径”视为直接触发 using-official-docs 的信号。
不要等用户显式写出 skill 名。
不要要求用户提供参考样稿来决定结构或流程。
`using-official-docs` 只是入口路由器和工作区初始化器，不能直接代替主 Skill 写章节、写表、写图、写 review 或写正式总稿。
这类任务的强制技能顺序是：`using-official-docs` -> `official-doc-core` -> 对应主 Skill / 公共 Skill。
不要把“已经读过 official-doc-core”当成“已经调用过 official-doc-core”；在写正文、表格、图示、review、revise、assemble 之前，必须先单独执行一次 `official-doc-core`。
一旦 `using-official-docs` 判断完下一步，必须立即切到对应主 Skill 或公共 Skill，再由后者继续执行。

入口 skill 是这类任务的强制第一步，用来完成：
- 判定主模板
- 初始化或复用 workspace/plan workspace/outputs workspace/tables workspace/figures workspace/review workspace/assembled
- 识别当前阶段
- 路由到主 Skill 或公共 Skill

如果用户只说“我要写 ZS-项目可行性报告，材料在 materials/test-case-zs/”，也必须立即触发 using-official-docs。
如果用户只说“我要写 完整科研项目模板，材料在 materials/test-case-full/”，也必须立即触发 using-official-docs。
不要跳过。
MSG
)

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$session_context"
else
  printf '{"additional_context":"%s"}\n' "$session_context"
fi
