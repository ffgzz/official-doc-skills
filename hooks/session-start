#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
session_context=$(cat <<'MSG'
<EXTREMELY_IMPORTANT>
你已加载“公文项目写作助手”。

当用户要你写正式项目材料时，默认先执行 `skills/using-official-docs/SKILL.md`。
当前工作方式不是“材料目录 + 固定模板”，而是“主题 + 章节要求 + 表图要求 + 字数要求”的提示词驱动。

强制规则：
- 先用 using-official-docs 解析 brief、初始化 `project-slug` 工作区、写 `00-section-plan.md`
- 再单独执行 `official-doc-core`
- 只有五类共性章节才调用专项 skill：
  - 项目背景
  - 研究内容
  - 创新点
  - 主要技术成果
  - 主要技术指标
- 其他章节直接按 brief 写作，不需要额外 skill
- 对上述五类章节，必须先做网络搜索并登记来源，不能硬编

公共流程仍保留：
`official-doc-table` -> `official-doc-figure` -> `official-doc-review` -> `official-doc-revise` -> `official-doc-assemble`
</EXTREMELY_IMPORTANT>
MSG
)

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$session_context"
else
  printf '{"additional_context":"%s"}\n' "$session_context"
fi
